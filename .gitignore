# Quarantined / deletable files parked for review (not shipped; recoverable on disk).
# Remove attic/ permanently with `rm -rf attic/` once confirmed unneeded.
attic/

# Documenter build products / auto-generated API page
docs/build/
docs/site/
docs/src/api.md

# Code-coverage artifacts (julia --code-coverage=user)
*.cov
lcov.info

# Slurm / local run artifacts
build/*.out
build/*.err
build/*.log
build/fortran_runs/
build/debug_out_*/
build/validate_out_*/
build/smoke_out_*/
build/fileInput*/
build/compare_nb*_plots/
build/compare_nb32_scan_plots/

# Run output directories (regenerated by timing / scan / compare jobs)
build/timing_runs/
build/*_tasks/
build/compare_nb*_scan20_gpu_*/

# Generated file-based inputs (regenerated by setup_fortran_file_inputs)
build/debug_nb*/fileInput*/

# Sysimage build products
build/*.so
build/*.ji

# Julia resolved environment: not pinned, so it always resolves fresh against
# the registry + Project.toml [compat]. Reproducibility of published results is
# guarded by [compat] bounds + the Fortran regression test.
Manifest.toml
Manifest-v*.toml

# Julia backup manifests
Manifest.toml.*.bak

# Experimental MPS / eigensolver benchmark + profiling scratch (one-off, regenerable).
# Production keepers (common/mps-scan-wrapper.sh, common/run_gacode_scan20_mps_task.jl)
# live in build/ subdirectories and are tracked explicitly; the scratch patterns below
# only match one-off scripts at the build/ top level.
build/batch_bench_*.sh
build/batch_diag_*.sh
build/batch_probe_*.sh
build/batch_profile_*.sh
build/batch_sweep_team_premium.sh
build/batch_gpu_sweep_premium.sh
build/batch_validate_mps_radius_premium.sh
build/batch_within_gpu_debug.sh
build/batch_cpu_nb32_premium.sh
build/batch_test_mps_*.sh
build/batch_run_gacode_scan20_mps.sh
build/batch_run_gacode_scan20_gpu_10nodes_2gpu.sh
build/bench_*.jl
build/microbench_*.jl
build/diag_*.jl
build/verify_*.jl
build/warntype_*.jl
build/probe_nb6.jl
build/run_probe_split.jl
build/mps-gate-wrapper.sh
build/mps-pin-wrapper.sh
build/mps-wrapper.sh

# eigenvector GPU-vs-CPU A/B experiment scripts + outputs (one-off)
build/run_eigvec_ab*.jl
build/batch_eigvec_ab_*.sh
build/eigvec_ab_*/
build/.layout_jobids

# Experimental run outputs / serialized matrices (regenerable)
build/*.jls
build/eig_warntype.txt
build/*_barrier_*/
build/mpsprof_*/
build/mpsval_*/
build/mpssweep_*/
build/mpsteamdiag_*/
build/probesplit_*/
build/tjlf_bench_env/

# Slurm job stdout/stderr and run logs. These land at the repo root (e.g.
# ad_speedup_<jobid>.out, iter_fuse_scan20_gpu_<jobid>.err) and throughout the
# build/ subtree (build/ad, build/timing, ...); the earlier build/*.{out,err,log}
# rules only matched the build/ top level. None are ever tracked.
*.out
*.err
*.log

# Serialized matrices / scan-output tables and per-radius task dirs anywhere under
# build/ (the earlier build/*.jls and build/*_tasks/ rules missed subdirectories
# like build/ad/*_tasks/ and build/ad/*.jls). No .jls/.txt are tracked.
build/**/*.jls
build/**/*.txt
build/**/*_tasks/

# Sysimage backups and one-off timing probe run dirs
build/*.so.bak
build/timing/probe_*/
