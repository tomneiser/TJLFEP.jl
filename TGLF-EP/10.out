TGLFEP_kwscale_scan.f90:                achar(mod(floor(10*factor_in),10)+iachar("0"))    //  &
TGLFEP_kwscale_scan.f90:                achar(mod(floor(100*factor_in),10)+iachar("0"))   //  &
TGLFEP_kwscale_scan.f90:                achar(mod(floor(1000*factor_in),10)+iachar("0"))
