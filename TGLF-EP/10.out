TGLFEP_ky_nEPscan.f90:    factor(i) = real(i)/10.0
TGLFEP_ky_nEPscan.f90:        write(20,10)factor(ifactor),(g(n),f(n),n=1,nmodes)
TGLFEP_ky_nEPscan.f90:10 format(F5.2,8F12.7)
TGLFEP_ky_widthscan.f90:    str_width = achar(floor(width_in)+iachar("0"))//'.'//achar(mod(floor(10*width_in),10)+iachar("0"))&
TGLFEP_ky_widthscan.f90:                //achar(mod(floor(100*width_in),10)+iachar("0"))
TGLFEP_ky_widthscan.f90:        write(9,10)w,(g(n),f(n),n=1,nmodes)
TGLFEP_ky_widthscan.f90:10 format(F5.2,8F12.7)
TGLFEP_mainsub.f90:      ! case(3) !The gamma and frequency vs nEP, like FIG. 4 in BassWaltz2010
