TGLFEP_interface.f90:  real, dimension(10) :: q_i  = 1.0
TGLFEP_kwscale_scan.f90:      str_sf =  achar(mod(floor(factor_in/100.),10)+iachar("0"))  //  &
TGLFEP_kwscale_scan.f90:                achar(mod(floor(factor_in/10.),10)+iachar("0"))   //  &
