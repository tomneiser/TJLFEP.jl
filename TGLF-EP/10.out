TGLFEP_driver.f90:    read(22,*,end=100) input_profile_method                                       ! EMB 10/2018
TGLFEP_driver.f90:  ! EMB 10/2020
TGLFEP_driver.f90:100 continue
TGLFEP_driver.f90:  select case (input_profile_method)              ! EMB 10/2018
TGLFEP_driver.f90:!      nn = 10
TGLFEP_driver.f90:  str_r = achar(ir/100+iachar("0"))//achar(mod(ir,100)/10+iachar("0"))//achar(mod(ir,10)+iachar("0"))
TGLFEP_driver.f90:!  goto 1000
TGLFEP_driver.f90:!        write(11,10) SFmin
TGLFEP_driver.f90:            write(11,10) SFmin(i)
TGLFEP_driver.f90:          dndr_crit(:) = 10000.
TGLFEP_driver.f90:          write(22,'(A33)') 'Density critical gradient (10^19/m^4)'
TGLFEP_driver.f90:          write(22,10) dndr_crit_out
TGLFEP_driver.f90:!        dpdr_EP(:) = EXPRO_ni(is_EP,:)*EXPRO_Ti(is_EP,:)*(EXPRO_dlnnidr(is_EP,:)+EXPRO_dlntidr(is_EP,:))*0.16022  ! 10 kPa/m
TGLFEP_driver.f90:          dpdr_crit = 10000.
TGLFEP_driver.f90:          dpdr_EP(:) = EXPRO_ni(is_EP,:)*EXPRO_Ti(is_EP,:)*(EXPRO_dlnnidr(is_EP,:)+EXPRO_dlntidr(is_EP,:))*0.16022  ! 10 kPa/m
TGLFEP_driver.f90:          write(22,'(A37)') 'Pressure critical gradient (10 kPa/m)'
TGLFEP_driver.f90:          write(22,10) dpdr_crit_out
TGLFEP_driver.f90:          write(11,10) SFmin(i)*as(irs+i-1,is)*100. !percent
TGLFEP_driver.f90:            write(11,10) SFmin(i)*betae(irs+i-1)*100.*as(irs+i-1,is)*taus(irs+i-1,is) !percent
TGLFEP_driver.f90:            write(11,10) SFmin(i)*betae(irs+i-1)*100.*as(irs+i-1,is)*taus(irs+i-1,is)*kappa(irs+i-1)**2 !percent
TGLFEP_driver.f90:        write(6,*) DEP_trace_scan(jtscale,i), DEP_trace_scan(jtscale,i)/(QL_ratio_scan(jtscale,i)+1.0E-10), QL_ratio_scan(jtscale,i)
TGLFEP_driver.f90:        write(6,*) DEP_trace_complete(i), DEP_trace_complete(i)/(QL_ratio_complete(i)+1.0E-10), QL_ratio_complete(i)
TGLFEP_driver.f90:10 format(F12.4)
TGLFEP_driver.f90:1000 continue
TGLFEP_generate_input.f90:           zeta(j) = zeta_min + ran_arr(4*ns+10)*(zeta_max-zeta_min)
